func (p *{{pascal .pipeline_name}}) Plan(_ context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, _ sparkwing.RunContext) error {
	paths := watchPaths{{pascal .pipeline_name}}()
	sparkwing.Job(plan, "work", p.work).
		SkipIf(contentkey.Unchanged({{pascal .pipeline_name}}BaseRef, paths...))
	return nil
}

// watchPaths{{pascal .pipeline_name}} splits the comma-listed watch paths
// into git pathspecs, dropping empty entries.
func watchPaths{{pascal .pipeline_name}}() []string {
	var out []string
	for _, p := range strings.Split({{pascal .pipeline_name}}WatchPaths, ",") {
		if p = strings.TrimSpace(p); p != "" {
			out = append(out, p)
		}
	}
	return out
}

