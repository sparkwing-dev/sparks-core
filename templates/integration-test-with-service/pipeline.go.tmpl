//
// Run integration tests against a throwaway {{.service_image}} container
// started before the tests and torn down after (even on failure/panic),
// via services.With. Needs a Docker daemon.
package jobs

import (
	"context"
	"strconv"
	"strings"
	"time"

	"github.com/sparkwing-dev/sparkwing/sparkwing"

	"github.com/sparkwing-dev/sparks-core/services"
)

// {{pascal .pipeline_name}} runs the test suite with a {{.service_image}}
// sidecar. Container port {{.service_port}} is published to an ephemeral
// host port, injected into the test as {{.port_env}} so it reaches the
// service at localhost.
type {{pascal .pipeline_name}} struct{ sparkwing.Base }

func ({{pascal .pipeline_name}}) ShortHelp() string {
	return "Integration tests against a throwaway {{.service_image}} container"
}

func (p *{{pascal .pipeline_name}}) Plan(_ context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, _ sparkwing.RunContext) error {
	sparkwing.Job(plan, "integration", p.run)
	return nil
}

func (p *{{pascal .pipeline_name}}) run(ctx context.Context) error {
	readyTimeout, err := time.ParseDuration({{quote .ready_timeout}})
	if err != nil {
		return err
	}
	spec := services.Spec{
		Image:         {{quote .service_image}},
		Env:           {{pascal .pipeline_name}}ParseEnv({{quote .env}}),
		ContainerPort: {{.service_port}},
		Ready:         strings.Fields({{quote .ready_cmd}}),
		ReadyTimeout:  readyTimeout,
	}
	return services.With(ctx, spec, func(ctx context.Context, hostPort int) error {
		_, err := sparkwing.Bash(ctx, {{quote .test_cmd}}).
			Env({{quote .port_env}}, strconv.Itoa(hostPort)).
			Run()
		return err
	})
}

// {{pascal .pipeline_name}}ParseEnv turns a "KEY=VAL,KEY=VAL" string into
// the container env map (e.g. POSTGRES_PASSWORD for the postgres image).
func {{pascal .pipeline_name}}ParseEnv(s string) map[string]string {
	m := map[string]string{}
	for _, kv := range strings.Split(s, ",") {
		kv = strings.TrimSpace(kv)
		if kv == "" {
			continue
		}
		if k, v, ok := strings.Cut(kv, "="); ok {
			m[strings.TrimSpace(k)] = strings.TrimSpace(v)
		}
	}
	return m
}

func init() {
	sparkwing.Register[sparkwing.NoInputs]({{quote .pipeline_name}}, func() sparkwing.Pipeline[sparkwing.NoInputs] { return &{{pascal .pipeline_name}}{} })
}
