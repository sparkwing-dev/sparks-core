package jobs

import (
	"context"

	"github.com/sparkwing-dev/sparkwing/sparkwing"
)

// {{pascal .pipeline_name}} installs dependencies, then runs lint,
// typecheck, and test as independent parallel nodes gated on install.
// The checks don't stop each other, so a single CI run surfaces every
// failure at once. Any of the check commands can be blanked out to drop
// its node (an empty typecheck-cmd is the plain-JS path).
type {{pascal .pipeline_name}} struct{ sparkwing.Base }

func ({{pascal .pipeline_name}}) ShortHelp() string {
	return "Node CI hygiene: lint + typecheck + test"
}

func ({{pascal .pipeline_name}}) Help() string {
	return "Installs dependencies, then runs lint, typecheck, and test in parallel. Targets Node {{.node_version}}+. Each check is independent so a single run surfaces every problem at once."
}

func ({{pascal .pipeline_name}}) Examples() []sparkwing.Example {
	return []sparkwing.Example{
		{Comment: "Run locally", Command: "sparkwing run {{.pipeline_name}}"},
	}
}
{{ $hasCheck := or .lint_cmd .typecheck_cmd .test_cmd }}
func (p *{{pascal .pipeline_name}}) Plan(ctx context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, run sparkwing.RunContext) error {
{{- if .install_cmd}}
{{- if $hasCheck}}
	install := sparkwing.Job(plan, "install", p.install)
{{- else}}
	sparkwing.Job(plan, "install", p.install)
{{- end}}
{{- end}}
{{- if .lint_cmd}}
	sparkwing.Job(plan, "lint", p.lint){{if .install_cmd}}.Needs(install){{end}}
{{- end}}
{{- if .typecheck_cmd}}
	sparkwing.Job(plan, "typecheck", p.typecheck){{if .install_cmd}}.Needs(install){{end}}
{{- end}}
{{- if .test_cmd}}
	sparkwing.Job(plan, "test", p.test){{if .install_cmd}}.Needs(install){{end}}
{{- end}}
	return nil
}
{{- if .install_cmd}}

