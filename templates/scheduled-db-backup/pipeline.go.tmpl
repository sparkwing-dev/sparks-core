package jobs

import (
	"context"

	"github.com/sparkwing-dev/sparkwing/sparkwing"

	"github.com/sparkwing-dev/sparks-core/dbbackup"
)

const (
	{{pascal .pipeline_name}}Secret  = {{quote .db_secret}}
	{{pascal .pipeline_name}}Engine  = {{quote .engine}}
	{{pascal .pipeline_name}}Dest    = {{quote .backup_dest}}
	{{pascal .pipeline_name}}Profile = {{quote .aws_profile}}
	{{pascal .pipeline_name}}Project = {{quote .project}}
)

type {{pascal .pipeline_name}} struct{ sparkwing.Base }

func ({{pascal .pipeline_name}}) ShortHelp() string {
	return "Dump the {{.engine}} database and upload a timestamped backup to {{.backup_dest}} (cron: {{.schedule}})"
}

func ({{pascal .pipeline_name}}) Examples() []sparkwing.Example {
	return []sparkwing.Example{
		{Comment: "Run the backup now", Command: "sparkwing run {{.pipeline_name}}"},
	}
}

func (p *{{pascal .pipeline_name}}) Plan(_ context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, _ sparkwing.RunContext) error {
	sparkwing.Job(plan, "backup", p.backup)
	return nil
}

// backup reads the source DSN from a sparkwing secret so it never lands
// in the pipeline source, then dumps, compresses, and ships the artifact
// to the configured destination. The cloud upload honors SPARKWING_DRY_RUN;
// the dump itself always runs, which is why this template is compile-only
// in the registry (it needs a reachable database).
func (p *{{pascal .pipeline_name}}) backup(ctx context.Context) error {
	dsn, err := sparkwing.Secret(ctx, {{pascal .pipeline_name}}Secret)
	if err != nil {
		return err
	}
	art, err := dbbackup.Dump(ctx, dbbackup.Config{
		Engine:     {{pascal .pipeline_name}}Engine,
		DSN:        dsn,
		Dest:       {{pascal .pipeline_name}}Dest,
		AWSProfile: {{pascal .pipeline_name}}Profile,
		Project:    {{pascal .pipeline_name}}Project,
	})
	if err != nil {
		return err
	}
	sparkwing.Annotate(ctx, "backup uploaded to "+art.URI)
	return nil
}

func init() {
	sparkwing.Register[sparkwing.NoInputs]({{quote .pipeline_name}}, func() sparkwing.Pipeline[sparkwing.NoInputs] { return &{{pascal .pipeline_name}}{} })
}
