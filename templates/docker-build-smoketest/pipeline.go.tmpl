// {{pascal .pipeline_name}} builds {{.image_tag}} from {{.dockerfile}}
// and, as a Verify postcondition, runs the image so a container that
// can't start fails the node at the verify stage.
type {{pascal .pipeline_name}} struct{ sparkwing.Base }

func ({{pascal .pipeline_name}}) ShortHelp() string {
	return "Build {{.image_tag}} from {{.dockerfile}} and smoke-test that it runs"
}

func (p *{{pascal .pipeline_name}}) Plan(_ context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, _ sparkwing.RunContext) error {
	timeout, err := time.ParseDuration({{quote .build_timeout}})
	if err != nil {
		return fmt.Errorf("build-timeout: %w", err)
	}
	sparkwing.Job(plan, "build", p.build).
		Verify(p.smokeTest).
		Retry(1, sparkwing.RetryAuto()).
		Timeout(timeout)
	return nil
}

func (p *{{pascal .pipeline_name}}) build(ctx context.Context) error {
	args := []string{"build", "-t", {{quote .image_tag}}, "-f", {{quote .dockerfile}}}
	args = append(args, buildArgFlags({{quote .build_args}})...)
	if target := {{quote .target}}; target != "" {
		args = append(args, "--target", target)
	}
	args = append(args, {{quote .build_context}})
	_, err := sparkwing.Exec(ctx, "docker", args...).Run()
	return err
}

// smokeTest runs the freshly-built image so a container that can't
// start fails the node at the verify stage. A non-empty verify-cmd is
// split on whitespace into arguments appended to the image's own
// entrypoint, so the real startup path is exercised and shell-less
// images still work.
func (p *{{pascal .pipeline_name}}) smokeTest(ctx context.Context) error {
	args := []string{"run", "--rm", {{quote .image_tag}}}
	args = append(args, strings.Fields({{quote .verify_cmd}})...)
	_, err := sparkwing.Exec(ctx, "docker", args...).Run()
	return err
}

// buildArgFlags parses a KEY=VAL,KEY=VAL string into a flat
// --build-arg KEY=VAL argv slice. Blank entries are skipped, so an
// empty spec yields no flags.
func buildArgFlags(spec string) []string {
	var out []string
	for _, pair := range strings.Split(spec, ",") {
		pair = strings.TrimSpace(pair)
		if pair == "" {
			continue
		}
		out = append(out, "--build-arg", pair)
	}
	return out
}

