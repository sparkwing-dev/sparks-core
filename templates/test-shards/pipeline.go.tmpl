//
// Run a test suite split into {{.shards}} parallel shards, gated by a
// node that passes only when every shard passes. Fully local.
package jobs

import (
	"context"
	"fmt"

	"github.com/sparkwing-dev/sparkwing/sparkwing"
)

const {{pascal .pipeline_name}}ShardTotal = {{.shards}}

// {{pascal .pipeline_name}} fans {{.shards}} shard jobs out in parallel,
// then a gate node depends on the whole group so it runs only when
// every shard passed.
type {{pascal .pipeline_name}} struct{ sparkwing.Base }

func ({{pascal .pipeline_name}}) ShortHelp() string {
	return "Run tests across {{.shards}} parallel shards with an all-pass gate"
}

func (p *{{pascal .pipeline_name}}) Plan(_ context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, _ sparkwing.RunContext) error {
	if {{pascal .pipeline_name}}ShardTotal < 1 {
		return fmt.Errorf("shards must be >= 1, got %d", {{pascal .pipeline_name}}ShardTotal)
	}
	idx := make([]int, {{pascal .pipeline_name}}ShardTotal)
	for i := range idx {
		idx[i] = i
	}
	shards := sparkwing.JobFanOut(plan, "shard", idx, func(i int) (string, any) {
		return fmt.Sprintf("shard-%d", i), &{{pascal .pipeline_name}}Shard{index: i}
	})
	sparkwing.Job(plan, "gate", p.gate).Needs(shards)
	return nil
}

// {{pascal .pipeline_name}}Shard runs one shard of the suite. Its test
// command sees SHARD_INDEX (0-based) and SHARD_TOTAL in the environment
// and selects its slice from them -- the default splits the module's
// packages by list position; a test runner's native --shard flag works
// too.
type {{pascal .pipeline_name}}Shard struct {
	sparkwing.Base
	index int
}

// Prefers biases every shard onto a runner advertising the configured
// label. It is a soft preference, not a hard Requires, so a
// single-runner setup still dispatches the shard.
func ({{pascal .pipeline_name}}Shard) Prefers() []string {
	label := {{quote .runner_label}}
	if label == "" {
		return nil
	}
	return []string{label}
}

func (s *{{pascal .pipeline_name}}Shard) Work(w *sparkwing.Work) (*sparkwing.WorkStep, error) {
	idx := s.index
	sparkwing.Step(w, "test", func(ctx context.Context) error {
		_, err := sparkwing.Bash(ctx, {{quote .test_cmd}}).
			Env("SHARD_INDEX", fmt.Sprintf("%d", idx)).
			Env("SHARD_TOTAL", fmt.Sprintf("%d", {{pascal .pipeline_name}}ShardTotal)).
			Run()
		return err
	})
	return nil, nil
}

func (p *{{pascal .pipeline_name}}) gate(ctx context.Context) error {
	sparkwing.Info(ctx, "all %d shards passed", {{pascal .pipeline_name}}ShardTotal)
	return nil
}

func init() {
	sparkwing.Register[sparkwing.NoInputs]({{quote .pipeline_name}}, func() sparkwing.Pipeline[sparkwing.NoInputs] { return &{{pascal .pipeline_name}}{} })
}
