// build-publish-binary`. Edit freely -- nothing here re-runs.
//
// Build a versioned, statically linked Go binary, checksum it, and
// publish both into a local release directory. Fully local: no cloud,
// registry, or cluster.
package jobs

import (
	"context"
	"crypto/sha256"
	"fmt"
	"os"
	"path/filepath"
	"runtime"
	"strings"

	"github.com/sparkwing-dev/sparkwing/sparkwing"

	"github.com/sparkwing-dev/sparks-core/release"
)

const (
	binaryName = {{quote .binary_name}}
	releaseDir = {{quote .release_dir}}
	mainPkg    = {{quote .main_package}}
	versionVar = {{quote .version_var}}
)

// {{pascal .pipeline_name}} builds {{.main_package}} into a versioned,
// statically linked binary, writes a SHA-256 checksums manifest, and
// publishes both into {{.release_dir}}/. A Verify postcondition re-hashes
// the published artifact so a corrupted copy fails the run at the verify
// stage.
type {{pascal .pipeline_name}} struct{ sparkwing.Base }

func ({{pascal .pipeline_name}}) ShortHelp() string {
	return "Build a versioned Go binary + checksum, publish to {{.release_dir}}/"
}

func (p *{{pascal .pipeline_name}}) Plan(_ context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, _ sparkwing.RunContext) error {
	sparkwing.Job(plan, "build-publish", p.buildPublish).
		Verify(p.verifyChecksum)
	return nil
}

// buildPublish derives a version from git (falling back to "dev" in a
// repo with no tags/commits), cross-builds the host platform with that
// version stamped via -ldflags into a trimmed, CGO-free binary, then
// writes a sha256sum-format checksums.txt over the release dir.
func (p *{{pascal .pipeline_name}}) buildPublish(ctx context.Context) error {
	version, err := release.DeriveVersion(ctx, release.VersionConfig{
		Describe:       true,
		DevFallback:    "dev",
		AllowNonSemver: true,
	})
	if err != nil {
		return err
	}
	artifacts, err := release.CrossBuildGo(ctx, release.CrossBuildConfig{
		MainPkg:    mainPkg,
		BinaryName: binaryName,
		Version:    version,
		Platforms:  []string{runtime.GOOS + "/" + runtime.GOARCH},
		OutDir:     releaseDir,
		LDFlags:    fmt.Sprintf("-X %s=%s", versionVar, version),
		Trimpath:   true,
	})
	if err != nil {
		return err
	}
	if err := release.Checksums(ctx, release.ChecksumConfig{Dir: releaseDir}); err != nil {
		return err
	}
	sparkwing.Info(ctx, "published %d artifact(s) for version %s", len(artifacts), version)
	sparkwing.Annotate(ctx, fmt.Sprintf("published %s %s", binaryName, version))
	return nil
}

// verifyChecksum re-reads checksums.txt and re-hashes every listed
// artifact, failing the node at the verify stage on any mismatch.
func (p *{{pascal .pipeline_name}}) verifyChecksum(ctx context.Context) error {
	root := sparkwing.WorkDir()
	if root == "" {
		root = "."
	}
	data, err := os.ReadFile(filepath.Join(root, releaseDir, "checksums.txt"))
	if err != nil {
		return fmt.Errorf("read checksums: %w", err)
	}
	for _, line := range strings.Split(strings.TrimSpace(string(data)), "\n") {
		fields := strings.Fields(line)
		if len(fields) != 2 {
			continue
		}
		want, name := fields[0], fields[1]
		got, err := sha256File(filepath.Join(root, releaseDir, name))
		if err != nil {
			return err
		}
		if want != got {
			return fmt.Errorf("checksum mismatch for %s", name)
		}
	}
	return nil
}

// sha256File returns the lowercase hex SHA-256 of a file's contents.
func sha256File(path string) (string, error) {
	data, err := os.ReadFile(path)
	if err != nil {
		return "", err
	}
	sum := sha256.Sum256(data)
	return fmt.Sprintf("%x", sum), nil
}

func init() {
	sparkwing.Register[sparkwing.NoInputs]({{quote .pipeline_name}}, func() sparkwing.Pipeline[sparkwing.NoInputs] { return &{{pascal .pipeline_name}}{} })
}
