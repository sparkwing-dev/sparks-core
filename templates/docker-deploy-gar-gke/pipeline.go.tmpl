// Scaffolded from the docker-deploy-gar-gke template. Edit freely --
// nothing here re-runs.
//
// A raw-composition DAG: each node calls a sparks-core block directly,
// so the orchestration (what runs when) is visible and editable. The
// blocks do the heavy lifting. This is the GCP twin of
// docker-deploy-ecr-eks: it authenticates the push to Google Artifact
// Registry, builds and pushes a content-addressed image, then bumps
// the gitops repo's kustomize image tag and waits for ArgoCD to sync
// the new revision to Synced + Healthy on GKE.
package jobs

import (
	"context"
	"strings"

	"github.com/sparkwing-dev/sparkwing/sparkwing"
	sparkwingDocker "github.com/sparkwing-dev/sparkwing/sparkwing/docker"

	"github.com/sparkwing-dev/sparks-core/deploy"
	"github.com/sparkwing-dev/sparks-core/docker"
	"github.com/sparkwing-dev/sparks-core/gcp"
)

// {{pascal .pipeline_name}} tests, builds {{.image}} to GAR ({{.registry}}),
// and deploys it to GKE through the gitops repo. The deploy node bumps the
// kustomize image tag, pushes, and waits for ArgoCD to report the new
// revision Synced + Healthy.
type {{pascal .pipeline_name}} struct{ sparkwing.Base }

func (p *{{pascal .pipeline_name}}) Plan(_ context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, _ sparkwing.RunContext) error {
{{if .test_cmd}}	test := sparkwing.Job(plan, "test", func(ctx context.Context) error {
		_, err := sparkwing.Bash(ctx, {{quote .test_cmd}}).Run()
		return err
	})
	build := sparkwing.Job(plan, "build", p.build).Needs(test)
{{else}}	build := sparkwing.Job(plan, "build", p.build)
{{end}}	sparkwing.Job(plan, "deploy", p.deploy).Needs(build)
	return nil
}

// build authenticates docker against the GAR host, then builds and pushes
// the image tagged with the content-addressed DeployTag. GAR auth is the
// GCP analog of the ECR login docker.BuildAndPush runs itself for ECR
// registries, so it is done explicitly here first.
func (p *{{pascal .pipeline_name}}) build(ctx context.Context) error {
	if err := gcp.ConfigureDockerAuth(ctx, garHost()); err != nil {
		return err
	}
	tags, err := sparkwingDocker.ComputeTags(ctx)
	if err != nil {
		return err
	}
	return docker.BuildAndPush(ctx, docker.BuildConfig{
		Image:      {{quote .image}},
		Dockerfile: "Dockerfile",
		Registries: []string{ {{quote .registry}} },
		Tags:       tags,
	})
}

// deploy hands the freshly pushed tag to the deploy dispatcher: for a
// remote target it bumps the kustomize image tag in the gitops repo
// (retrying on concurrent pushes) and kicks ArgoCD, waiting until the app
// reports Synced + Healthy; against a local kind cluster it applies the
// repo's own manifests instead.
func (p *{{pascal .pipeline_name}}) deploy(ctx context.Context) error {
	tags, err := sparkwingDocker.ComputeTags(ctx)
	if err != nil {
		return err
	}
	return deploy.Run(ctx, deploy.Config{
		GitopsRepo: {{quote .gitops_repo}},
		GitopsPath: {{quote .gitops_path}},
		ECR:        {{quote .registry}},
		Images:     []string{ {{quote .image}} },
		Tag:        tags.DeployTag(),
		AppName:    {{quote .app_name}},
		Namespace:  {{quote .namespace}},
	})
}

// garHost is the Artifact Registry host that docker authenticates against,
// the first path segment of the registry URL (e.g. "us-west1-docker.pkg.dev"
// from "us-west1-docker.pkg.dev/proj/repo").
func garHost() string {
	return strings.SplitN({{quote .registry}}, "/", 2)[0]
}

func init() {
	sparkwing.Register[sparkwing.NoInputs]({{quote .pipeline_name}}, func() sparkwing.Pipeline[sparkwing.NoInputs] {
		return &{{pascal .pipeline_name}}{}
	})
}
