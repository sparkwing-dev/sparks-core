// deploy bumps the gitops repo's kustomize image tag and commits.
// The ArgoCD sync that picks up the commit lives outside this
// pipeline; clusters with auto-sync enabled apply on next reconcile.
func ({{pascal .pipeline_name}}) deploy(ctx context.Context) error {
	tag := buildTag()
	full := {{quote .gar}}+"/"+{{quote .image}}+":"+tag
	tmp := "/tmp/gitops-{{.app_name}}-" + tag
	if _, err := sparkwing.Exec(ctx, "git", "clone", "--depth=1",
		{{quote .gitops_repo}}, tmp).Run(); err != nil {
		return err
	}
	defer sparkwing.Exec(ctx, "rm", "-rf", tmp).Run() //nolint:errcheck
	if _, err := sparkwing.Bash(ctx, fmt.Sprintf(
		`cd %s/%s && kustomize edit set image %s=%s`,
		tmp, {{quote .gitops_path}}, {{quote .image}}, full)).Run(); err != nil {
		return err
	}
	commitMsg := fmt.Sprintf("bump {{.image}} to %s", tag)
	if _, err := sparkwing.Bash(ctx, fmt.Sprintf(
		`cd %s && git add -A && git commit -m %q && git push`,
		tmp, commitMsg)).Run(); err != nil {
		return err
	}
	sparkwing.Info(ctx, "deployed {{.image}} %s to {{.namespace}}", tag)
	return nil
}

