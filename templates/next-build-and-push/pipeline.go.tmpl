//
// Build-only flavor of the static-deploy templates. Produces an
// out.tar.gz artifact and uploads it, keyed by commit SHA; the deploy
// step lives elsewhere (typically a separate pipeline gated on manual
// approval).
package jobs

import (
	"context"
	"fmt"
	"time"

	"github.com/sparkwing-dev/sparkwing/sparkwing"
)

// {{pascal .pipeline_name}} builds a Next.js static export and uploads
// the resulting tarball to an S3 artifact bucket, keyed by commit SHA.
type {{pascal .pipeline_name}} struct {
	sparkwing.Base
	// key is the S3 object key computed once in Plan from the commit
	// SHA and reused by upload, so the artifact is addressable by the
	// commit it was built from.
	key string
}

func ({{pascal .pipeline_name}}) ShortHelp() string {
	return "Build Next.js static export, upload artifact tarball"
}

func ({{pascal .pipeline_name}}) Help() string {
	return "Builds the Next.js static export and uploads out.tar.gz to s3://{{.artifact_bucket}}/{{.artifact_prefix}}/<sha>.tar.gz. No deploy step -- ship the tarball, gate the deploy."
}

func ({{pascal .pipeline_name}}) Examples() []sparkwing.Example {
	return []sparkwing.Example{
		{Comment: "Run locally", Command: "sparkwing run {{.pipeline_name}}"},
	}
}

func (p *{{pascal .pipeline_name}}) Plan(ctx context.Context, plan *sparkwing.Plan, _ sparkwing.NoInputs, run sparkwing.RunContext) error {
	sha := run.Git.ShortSHA()
	if sha == "" {
		sha = time.Now().UTC().Format("20060102-150405")
	}
	p.key = fmt.Sprintf("%s/%s.tar.gz", {{quote .artifact_prefix}}, sha)
	build := sparkwing.Job(plan, "build", p.build).
		Retry(2, sparkwing.RetryBackoff(3*time.Second)).
		Timeout(20 * time.Minute)
	pack := sparkwing.Job(plan, "tarball", p.tarball).Needs(build)
	sparkwing.Job(plan, "upload", p.upload).
		Needs(pack).
		Retry(2, sparkwing.RetryBackoff(3*time.Second)).
		Timeout(10 * time.Minute)
	return nil
}

func ({{pascal .pipeline_name}}) build(ctx context.Context) error {
	_, err := sparkwing.Bash(ctx, {{quote .build_cmd}}).Run()
	return err
}

func ({{pascal .pipeline_name}}) tarball(ctx context.Context) error {
	_, err := sparkwing.Exec(ctx, "tar", "-czf", "out.tar.gz", "-C", {{quote .out_dir}}, ".").Run()
	return err
}

func (p *{{pascal .pipeline_name}}) upload(ctx context.Context) error {
	dest := "s3://" + {{quote .artifact_bucket}} + "/" + p.key
	if _, err := sparkwing.Exec(ctx, "aws", "s3", "cp", "out.tar.gz", dest).Run(); err != nil {
		return err
	}
	sparkwing.Info(ctx, "uploaded artifact: %s", dest)
	return nil
}

func init() {
	sparkwing.Register[sparkwing.NoInputs]({{quote .pipeline_name}}, func() sparkwing.Pipeline[sparkwing.NoInputs] { return &{{pascal .pipeline_name}}{} })
}
