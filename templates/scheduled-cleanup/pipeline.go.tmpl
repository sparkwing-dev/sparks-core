func (p *{{pascal .pipeline_name}}) prune(ctx context.Context) error {
	if {{pascal .pipeline_name}}MaxDays <= 0 {
		return fmt.Errorf("max-age-days must be a positive integer, got %d", {{pascal .pipeline_name}}MaxDays)
	}
	dry := sparkwing.IsDryRun(ctx)
	dir := sparkwing.Path({{pascal .pipeline_name}}Dir)
	if _, err := os.Stat(dir); os.IsNotExist(err) {
		sparkwing.Info(ctx, "%s does not exist; nothing to prune", dir)
		return nil
	}
	cutoff := time.Now().AddDate(0, 0, -{{pascal .pipeline_name}}MaxDays)
	var removed int
	err := filepath.WalkDir(dir, func(path string, d os.DirEntry, err error) error {
		if err != nil {
			return err
		}
		if d.IsDir() || !d.Type().IsRegular() {
			return nil
		}
		info, err := d.Info()
		if err != nil {
			return err
		}
		if info.ModTime().Before(cutoff) {
			if dry {
				sparkwing.Info(ctx, "would remove %s", path)
				removed++
				return nil
			}
			if rerr := os.Remove(path); rerr != nil {
				return rerr
			}
			removed++
		}
		return nil
	})
	if err != nil {
		return err
	}
	verb := "pruned"
	if dry {
		verb = "would prune"
	}
	sparkwing.Info(ctx, "%s %d file(s) older than %d days from %s", verb, removed, {{pascal .pipeline_name}}MaxDays, dir)
	sparkwing.Annotate(ctx, fmt.Sprintf("%s %d file(s)", verb, removed))
	return nil
}

