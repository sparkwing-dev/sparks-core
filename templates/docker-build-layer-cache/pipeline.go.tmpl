// build resolves the cache backend into BuildKit --cache-from /
// --cache-to specs and runs a single BuildKit `docker build` that reads
// and writes that cache. DOCKER_BUILDKIT is forced on so the cache flags
// and --build-arg forwarding are honored.
func (p *{{pascal .pipeline_name}}) build(ctx context.Context) error {
	cacheFrom, cacheTo, err := docker.BuildCacheRef({{quote .cache_backend}}, {{quote .cache_ref}})
	if err != nil {
		return err
