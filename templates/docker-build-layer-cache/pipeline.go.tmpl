	args := []string{"build", "-f", {{quote .dockerfile}}}
	args = append(args, "--cache-from", cacheFrom, "--cache-to", cacheTo)
	args = append(args, buildArgFlags({{quote .build_args}})...)
	args = append(args, "-t", {{quote .image_tag}}, {{quote .build_context}})

	_, err = sparkwing.Exec(ctx, "docker", args...).Env("DOCKER_BUILDKIT", "1").Run()
	return err
}

// buildArgFlags parses a KEY=VAL,KEY=VAL string into a flat
// --build-arg KEY=VAL argv slice. Blank entries are skipped, so an empty
// spec yields no flags.
func buildArgFlags(spec string) []string {
	var out []string
	for _, pair := range strings.Split(spec, ",") {
		pair = strings.TrimSpace(pair)
		if pair == "" {
			continue
		}
		out = append(out, "--build-arg", pair)
	}
	return out
}

